# For local Supabase (default after running `supabase start` in this repo):
VITE_SUPABASE_URL=http://127.0.0.1:55321
VITE_SUPABASE_ANON_KEY=your_local_publishable_key_here

# For a hosted Supabase project, replace with:
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_public_key_here
